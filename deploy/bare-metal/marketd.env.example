# systemd EnvironmentFile syntax (KEY=VALUE; no shell expansion).
RUST_LOG=info

# Required acknowledgement for this repository state. The packaged service
# refuses to start while this is 0 because process readiness currently proves
# only that placeholder role handlers and the metrics listener bootstrapped.
# It does NOT prove RPC, peer networking, durable execution, or recovery.
DEXOS_ACKNOWLEDGE_SKELETON=0

# Keep metrics loopback-only by default. Set to 1 only after an explicit network
# exposure review; the endpoint has no authentication.
DEXOS_ALLOW_PUBLIC_METRICS=0
